        "jsonBody": "={\n  \"pipelineId\": \"4BQb45bxmAFhiSCSU35e\",\n  \"pipelineStageId\": \"fabe9eff-921c-4a6c-a711-98e87797b3f1\",\n  \"locationId\": \"YOUR_GHL_LOCATION_ID_ACS\",\n  \"contactId\": \"{{ $json.body.contactId }}\",\n  \"name\": \"{{ $json.body.contactName || 'Email Lead' }}\",\n  \"status\": \"open\",\n  \"source\": \"cold-email\"\n}",
